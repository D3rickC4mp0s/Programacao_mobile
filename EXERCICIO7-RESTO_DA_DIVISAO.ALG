Algoritmo "exercicio7-resto_da_divisao"
// 
//  
// Descriçăo   : mostrar o resto da divisăo de um número por 2
// Autor(a)    : Derick Campos Silva
// Data atual  : 13/02/2026
Var
// Seçăo de Declaraçőes das variáveis 
N1: inteiro
divisao: real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
escreva("Qual o número que vocę deseja calcular? ")
leia(N1)
divisao <- N1/2

escreva("O resto da divisăo é: ",divisao)

Fimalgoritmo