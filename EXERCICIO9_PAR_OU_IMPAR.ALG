Algoritmo "exercicio9_par_ou_impar"
// 
//  
// Descriçăo   : descobrir se um número é par ou ímpar
// Autor(a)    : Derick Campos Silva (yasmin)
// Data atual  : 26/02/2026
Var
// Seçăo de Declaraçőes das variáveis 
num:inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
escreva("Qual é o seu número?")
leia(num)

se (num%2=0)entao
escreva ("Seu número é par!")
senao
escreva ("Seu número é ímpar!")
fimse

Fimalgoritmo