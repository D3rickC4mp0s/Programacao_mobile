Algoritmo "exercício1-saudaçao"
// 
//  
// Descrição   : mostrar o nome
// Autor(a)    : Derick Campos Silva (Yasmin)
// Data atual  : 13/02/2026
Var
// Seção de Declarações das variáveis 
nome:caractere

Inicio
// Seção de Comandos, procedimento, funções, operadores, etc... 
escreva("Qual é seu nome? ")
leia(nome)
escreva("Seja bem vindo ",nome)
Fimalgoritmo
