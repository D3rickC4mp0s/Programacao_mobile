Algoritmo "exercício1-saudaçao"
// 
//  
// Descriçăo   : mostrar o nome
// Autor(a)    : Derick Campos Silva (Yasmin)
// Data atual  : 13/02/2026
Var
// Seçăo de Declaraçőes das variáveis 
nome:caractere

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
escreva("Qual é seu nome? ")
leia(nome)
escreva("Seja bem vindo ",nome)
Fimalgoritmo